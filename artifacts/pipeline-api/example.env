# =============================================================================
# Dataset Engine - Environment Variables Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Usage: cp example.env .env

# -----------------------------------------------------------------------------
# REQUIRED: OpenAI API Configuration
# -----------------------------------------------------------------------------
# Your OpenAI API key for LLM-based record generation.
# Get your key at: https://platform.openai.com/api-keys
AI_INTEGRATIONS_OPENAI_API_KEY=

# Optional: Custom OpenAI-compatible API base URL
# Uncomment and set if using a different endpoint (e.g., for Azure OpenAI)
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# OPTIONAL: HuggingFace Hub Upload
# -----------------------------------------------------------------------------
# Your HuggingFace token for uploading datasets to the Hub.
# Get your token at: https://huggingface.co/settings/tokens
# Required only if you plan to use the "Push to Hub" feature.
HUGGINGFACE_TOKEN=

# -----------------------------------------------------------------------------
# OPTIONAL: Pipeline Configuration
# -----------------------------------------------------------------------------
# Port for the FastAPI server (default: 8000)
# PIPELINE_PORT=8000

# Maximum number of concurrent pipeline runs (default: 4)
# PIPELINE_CONCURRENCY=4

# -----------------------------------------------------------------------------
# OPTIONAL: API Authentication
# -----------------------------------------------------------------------------
# API key for authenticating requests to the /api/v1/* endpoints.
# When set, all /api/v1/* routes require: Authorization: Bearer <API_KEY>
# Leave empty to disable authentication (not recommended for production).
# API_KEY=your-secret-api-key-here
